{
  "name": "ejemplo-ts-node-web",
  "version": "1.0.0",
  "description": "Programa en consola y navegador con TypeScript",
  "main": "src/index.ts",
  "scripts": {
    "build:terminal":"webpack --config-name TerminalConfig --env archivo=.env.local",
    "start:terminal": "node dist/terminal/bundle.js --terminal",
    "build:web":"webpack --config-name WebConfig",
    "start:web":"webpack serve --config-name WebConfig --env archivo=.env.local",
    "build":"webpack",
    "test":"echo\"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "prompt-sync": "^4.2.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "ts-node": "^10.9.2",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4",
    "ts-loader": "^9.5.1",
    "html-webpack-plugin": "^5.6.0"
  }
}
